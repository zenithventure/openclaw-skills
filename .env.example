# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Email Configuration
# IMAP server address for reading incoming emails
IMAP_HOST=imap.example.com

# Email address used for receiving support tickets
EMAIL_USER=support@yourdomain.com

# Email password or app-specific password for authentication
EMAIL_PASSWORD=your-email-password

# GitHub Configuration
# Personal Access Token with repo scope for creating PRs and pushing changes
# This token is used by both the cron job (GitHub poll) and ACP sessions (git push)
GITHUB_TOKEN=ghp_your-github-personal-access-token

# Note: Claude Code is accessed via ACP (acpx backend)
# No local Claude Code installation required
# ACP spawns Claude Code using the @zed-industries/claude-agent-acp adapter
